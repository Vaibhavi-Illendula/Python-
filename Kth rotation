def findMin(nums):
        low=0
        high=len(nums)-1
        ans=float("inf")
        idx=0
        while(low<=high):
            mid=(low+high)//2
            if(nums[low]<=nums[mid]):
                if(nums[low]<ans):
                    ans=nums[low]
                    idx=low
                low=mid+1
            elif(nums[mid]<=nums[high]):
                if(nums[mid]<ans):
                    ans=nums[mid]
                    idx=mid
                high=mid-1
        return idx
